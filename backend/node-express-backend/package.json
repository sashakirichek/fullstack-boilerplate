{
  "name": "node-express-backend",
  "version": "1.0.0",
  "description": "Express backend on Cloudflare Workers with D1 database and Prisma ORM",
  "main": "index.js",
  "scripts": {
    "dev": "wrangler dev",
    "build": "prisma generate && tsc",
    "start": "node dist/index.ts",
    "test": "jest --config jest.config.js",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:migrate:local": "wrangler d1 migrations apply fullstack-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply fullstack-db --remote",
    "artillery": "artillery run artillery.yml",
    "deploy:test": "wrangler deploy --env test",
    "deploy:prod": "wrangler deploy"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/adapter-d1": "^6.0.0",
    "@prisma/client": "^6.0.0",
    "cloudflare": "5.2.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.6",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.0.0"
  }
}
